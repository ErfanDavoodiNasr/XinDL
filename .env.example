# Application Settings
ENVIRONMENT=production

# Telegram Bot Settings
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789

# =======================================================
# Deployment Settings (Used automatically by platform.sh)
# =======================================================
SERVER_IP=
SERVER_USER=root
SERVER_PASSWORD=
PROJECT_DIR=/opt/XinDL

# =======================================================
# Local Telegram API Settings (For >50MB files)
# Get ID/HASH from https://my.telegram.org
# =======================================================
USE_LOCAL_API=True
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Concurrency (tune for your server)
MAX_CONCURRENT_DOWNLOADS=3
MAX_CONCURRENT_INFO=5
