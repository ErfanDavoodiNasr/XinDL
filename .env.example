# =======================================================
# Application Settings
# =======================================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# =======================================================
# Telegram Bot Settings
# =======================================================
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789

# =======================================================
# Deployment Settings (Used automatically by platform.sh)
# =======================================================
SERVER_IP=
SERVER_USER=root
SERVER_PASSWORD=
PROJECT_DIR=/opt/XinDL

# =======================================================
# Local Telegram API Settings (For >50MB files)
# Get ID/HASH from https://my.telegram.org
# =======================================================
USE_LOCAL_API=True
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_LOCAL_API_URL=http://127.0.0.1:8081
LOCAL_API_STARTUP_TIMEOUT=120

# =======================================================
# Concurrency & Performance
# Tuned for 1 GB RAM / 1 CPU (AUTO_TUNE overrides at runtime)
# =======================================================
AUTO_TUNE_RESOURCES=True
MAX_CONCURRENT_DOWNLOADS=1
MAX_CONCURRENT_INFO=2
MAX_CONCURRENT_UPLOADS=1
MAX_BACKGROUND_TASKS=3
THREAD_POOL_WORKERS=2
USER_RATE_LIMIT_PER_MINUTE=10
USER_MAX_ACTIVE_DOWNLOADS=1
YTDLP_FRAGMENT_CONCURRENCY=2
YTDLP_TIMEOUT=300

# =======================================================
# Downloader Settings
# =======================================================
COOKIES_FILE=cookies/cookies.txt
USE_COOKIES=False
SKIP_FRAME_DECODE_VALIDATION=True

# =======================================================
# Proxy (OPTIONAL — geo-restricted videos only)
# Example: PROXY_URL=socks5://user:pass@host:1080
# =======================================================
# PROXY_URL=
